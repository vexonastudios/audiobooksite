# ── Database ──────────────────────────────────────────────────────────────────
# Your Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_api_key_here
# The voice ID to use for bumper announcements
# Find this in your ElevenLabs dashboard under Voices
ELEVENLABS_VOICE_ID=your_voice_id_here
# Model — "eleven_multilingual_v2" or "eleven_turbo_v2" (faster/cheaper)
ELEVENLABS_MODEL=eleven_turbo_v2

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=scrollreader-audio
# The folder inside your bucket where radio files will be stored
R2_RADIO_PREFIX=radio/

# ── Generation settings ───────────────────────────────────────────────────────
# Target block duration in seconds (default: 7200 = 2 hours)
TARGET_DURATION_SECS=7200
# Minimum chapter duration to include (seconds) — skip very short chapters
MIN_CHAPTER_SECS=300
# Maximum chapters from the same book in a row
MAX_CONSECUTIVE_SAME_BOOK=2
